NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=4310
FRONTEND_ORIGIN=http://127.0.0.1:5320
FRONTEND_ORIGINS=http://127.0.0.1:5320

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=15m
BCRYPT_ROUNDS=12
ATTACHMENT_ROOT=C:\AutomationProject\RAP

SESSION_SECRET=change-this-to-a-long-random-session-secret
SESSION_COOKIE_NAME=automation_request_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=strict
SESSION_IDLE_TIMEOUT_MINUTES=15
FORCE_HTTPS=false
ENABLE_HSTS=false
TRUST_PROXY_HOPS=0

SQL_SERVER=127.0.0.1
SQL_PORT=1433
SQL_DATABASE=AutomationRequest
SQL_USER=
SQL_PASSWORD=
SQL_ENCRYPT=false
SQL_TRUST_SERVER_CERTIFICATE=true

SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

MS365_CLIENT_ID=
MS365_TENANT_ID=
MS365_CLIENT_SECRET=
MS365_SCOPES=openid profile email User.Read
MS365_REDIRECT_URI=http://127.0.0.1:4310/api/auth/microsoft/callback
